      @backstage/plugin techdocs react ``` 6. In the directory containing the components
      of your custom TechDocs add-on, delete any default files or file components
      that are not required for your add-on, such as the routes.ts file or components
      of the index.tsx and plugins.ts files. 7. In the plugins.ts file, add the following
      code: ```java $ import { createPlugin } from ''@backstage/core-plugin-api'';
      $ import { createTechDocsAddonExtension } from ''@backstage/plugin-techdocs-react'';
      $ export const <new_plugin_for_techdocs_add on> = createPlugin({ id: ''<new_techdocs_add
