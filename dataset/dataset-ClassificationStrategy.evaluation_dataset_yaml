      "http://json-schema.org/draft-07/schema#" } }, { "name": "IS_ENTITY_KIND", "description":
      "Allow entities matching a specified kind", "resourceType": "catalog-entity",
      "paramsSchema": { "type": "object", "properties": { "kinds": { "type": "array",
      "items": { "type": "string" }, "description": "List of kinds to match at least
      one of" } }, "required": [ "kinds" ], "additionalProperties":'
