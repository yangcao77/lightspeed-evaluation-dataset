      organization: type: string title: Owner of the repository name: type: string
      title: Name of the repository branchName: type: string title: Branch to add
      the catalog entity to targetBranchName: type: string title: Branch to target
      the PR/MR to gitProviderHost: type: string title: Git provider host ``` ## Setting
